# yemredev.com — environment variables
# Copy to .env.local and fill in values you need.
# All AI / email values are placeholders — final providers chosen in later phases.

# ─────────────────────────────────────────────
# Phase 6 — AI Assistant provider
# Pick ONE provider when Phase 6 starts and uncomment the matching block.
# ─────────────────────────────────────────────
# AI_PROVIDER=openai

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash

# Groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# Phase 5 — Contact form delivery
# Pick ONE provider when Phase 5 starts.
# ─────────────────────────────────────────────
# CONTACT_PROVIDER=resend
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=hello@yemredev.com
# CONTACT_FROM_EMAIL=contact@yemredev.com

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://yemredev.com
