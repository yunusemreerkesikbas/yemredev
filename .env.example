# yemredev.com — environment variables
# Copy to .env.local and fill in values you need.

# ─────────────────────────────────────────────
# Phase 6 — AI Assistant provider
# Selected provider: OpenAI (gpt-4o-mini)
# See docs/3rd-party/ai-providers.md for the decision log.
# ─────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Other providers kept commented for future swap.
# Swap by replacing the model wiring in lib/ai/openai.ts.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# Phase 6 — Rate limiting (Upstash Redis)
# Required in production. If unset, /api/chat runs UNRATED and the
# server logs a one-time warning (acceptable for local dev only).
# Create a free Redis at https://console.upstash.com/
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────
# Phase 5 — Contact form delivery
# Pick ONE provider when Phase 5 starts.
# ─────────────────────────────────────────────
# CONTACT_PROVIDER=resend
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=hello@yemredev.com
# CONTACT_FROM_EMAIL=contact@yemredev.com

# ─────────────────────────────────────────────
# SEO & Analytics
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yemredev.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
